{
	"name": "@antonii22/scribe2",
	"version": "0.0.6",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"build:wc": "vite build -c vite.wc.config.ts && tsc -p tsconfig.types.json && node -e \"const fs = require('fs'); fs.mkdirSync('dist', { recursive: true }); fs.copyFileSync('src/lib/styles/scribe.css', 'dist/scribe.css')\"",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "npm run build:wc",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"main": "./dist/scribe.js",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/docbusters/scribe2.git"
	},
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/scribe.js"
		},
		"./scribe.css": "./dist/scribe.css"
	},
	"peerDependencies": {
		"svelte": "^5.55.2"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^22",
		"@types/sortablejs": "^1.15.9",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"svelte": "^5.55.2",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"bits-ui": "^2.18.1",
		"katex": "^0.17.0",
		"layerchart": "^2.0.0",
		"sortablejs": "^1.15.7",
		"svelte-maplibre-gl": "^2.0.1",
		"uuid": "^14.0.0"
	}
}
